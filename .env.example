# ─────────────────────────────────────────────────────────────────────────────
# Chorus Engine — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and adjust values as required:
#   cp .env.example .env
#
# Docker Compose will automatically load .env from the project root.
# ─────────────────────────────────────────────────────────────────────────────

# Whisper model size: tiny | base | small | medium | large
# "base" (~145 MB) is recommended for CPU-only environments.
# "small" (~461 MB) offers improved accuracy at the cost of speed.
WHISPER_MODEL=base

# Compute device: cpu | cuda
# Set to "cuda" only if a compatible NVIDIA GPU is available.
WHISPER_DEVICE=cpu

# Language hint for Whisper (BCP-47 code, e.g. "en", "fr", "de").
# Leave blank for automatic language detection.
WHISPER_LANGUAGE=
