# ─────────────────────────────────────────────────────────────────────────────
# Chorus Engine — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and adjust values as required:
#   cp .env.example .env
#
# Docker Compose will automatically load .env from the project root.
# ─────────────────────────────────────────────────────────────────────────────

# Whisper model size: tiny | base | small | medium | large
# "base" (~145 MB) is recommended for CPU-only environments.
# "small" (~461 MB) offers improved accuracy at the cost of speed.
# Tip — Apple Silicon native, 8 GB unified memory: use "small" or "medium".
#        "large" may exceed available memory on 8 GB configurations.
WHISPER_MODEL=base

# Compute device: cpu | cuda | mps
# Leave blank to auto-detect (recommended): CUDA → MPS → CPU.
#   cpu   Works everywhere. Default if no GPU is found.
#   cuda  NVIDIA GPU. Linux native or Windows via Docker Desktop + WSL2.
#   mps   Apple Silicon GPU. Native macOS only — not available inside Docker.
WHISPER_DEVICE=

# Language hint for Whisper (BCP-47 code, e.g. "en", "fr", "de").
# Leave blank for automatic language detection.
WHISPER_LANGUAGE=

# ── LLM Reconstruction (optional) ────────────────────────────────────────────
# Uses a local Ollama model to resolve LOW-confidence tokens after consensus.
# Requires Ollama installed and running separately — see the Help page in the
# UI for step-by-step setup, or visit https://ollama.com.
# Leave all values unset (or the checkbox unticked in the UI) to disable.
#
# Recommended model: qwen2.5:3b (~2 GB download) — fast, and reliably follows
# the "respond with only the token" instruction this feature depends on.
# For technical/rare-vocabulary audio, qwen2.5:14b (~9 GB, 16 GB RAM
# recommended) retains more long-tail vocabulary at the cost of speed.
#
# Quick start:
#   brew install ollama
#   ollama serve
#   ollama pull qwen2.5:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_SECONDS=20
