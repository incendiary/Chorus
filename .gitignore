# ─────────────────────────────────────────────────────────────────────────────
# Chorus Engine — .gitignore
# Baseline: incendiary/Bedrock (https://github.com/incendiary/Bedrock)
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets & Environment Variables ──────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets.json
secrets.yaml
secrets.toml
credentials.json
service_account*.json

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
.eggs/
dist/
build/
*.so
*.dylib

# ── Virtual Environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.python-version
pyvenv.cfg

# ── Testing & Coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.coveragerc
nosetests.xml
test-results/

# ── Linting & Type Checking ───────────────────────────────────────────────────
.ruff_cache/
.mypy_cache/
.dmypy.json
dmypy.json
pyrightconfig.json
.proxyai/

# ── Security Scanning ─────────────────────────────────────────────────────────
bandit-report.json
.bandit
gitleaks-report.json
safety-report.json
pip-audit-report.json
.secrets.baseline

# ── Chorus Runtime Outputs ────────────────────────────────────────────────────
outputs/
sample_audio/

# ── Audio Files ───────────────────────────────────────────────────────────────
*.wav
*.m4a
*.mp3
*.mp4
*.aac
*.flac
*.ogg
*.webm
*.qta

# ── Whisper Model Cache ───────────────────────────────────────────────────────
.cache/
*.pt
*.bin

# ── Docker Build Artefacts ────────────────────────────────────────────────────
.docker/
docker-compose.override.yml

# ── IDE & Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
.serena/
*.swp
*.swo
*.swn
*~
.project
.classpath
.settings/

# ── Operating System ──────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Temporary Files ───────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.log
*.pid
*.seed
*.pid.lock

# ── Archives (prevent accidental re-commit of zip artefacts) ─────────────────
*.zip
*.tar.gz
*.tar.bz2
*.rar
*.7z
gh_init.sh
